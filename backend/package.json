{
  "name": "bmc-iot-backend",
  "version": "1.0.0",
  "description": "Milk BMC IoT Monitoring Platform - Backend API",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "lint": "eslint src/",
    "db:migrate": "npx sequelize-cli db:migrate",
    "db:migrate:undo": "npx sequelize-cli db:migrate:undo:all",
    "db:seed": "npx sequelize-cli db:seed:all",
    "db:seed:undo": "npx sequelize-cli db:seed:undo:all",
    "db:reset": "npm run db:migrate:undo && npm run db:migrate && npm run db:seed"
  },
  "dependencies": {
    "fastify": "^5.3.3",
    "@fastify/cors": "^11.0.0",
    "@fastify/helmet": "^13.0.0",
    "@fastify/rate-limit": "^10.2.0",
    "@fastify/swagger": "^9.5.0",
    "@fastify/swagger-ui": "^6.0.0",
    "@fastify/jwt": "^9.1.0",
    "@fastify/multipart": "^9.0.0",
    "@fastify/static": "^8.1.0",
    "@fastify/websocket": "^11.0.0",
    "sequelize": "^6.37.5",
    "pg": "^8.13.1",
    "pg-hstore": "^2.3.4",
    "joi": "^17.13.3",
    "bcrypt": "^5.1.1",
    "ioredis": "^5.4.2",
    "@influxdata/influxdb-client": "^1.35.0",
    "mqtt": "^5.10.4",
    "bullmq": "^5.34.8",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "nodemailer": "^6.9.16",
    "dotenv": "^16.4.7",
    "uuid": "^11.1.0",
    "date-fns": "^4.1.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.9",
    "sequelize-cli": "^6.6.2",
    "eslint": "^9.17.0"
  }
}
